---
// Illustrazione "1 mattoncino vs 1000" — disuguaglianza del reddito, Italia 1980→2024.
// Concetto: 1 mattoncino = 50 €. Il 10% più povero ha guadagnato 50 € in 45 anni (1 mattoncino);
// il 10% più ricco ha guadagnato ~50.000 € → 1000 mattoncini.
// Palette ereditata da Chart_3.2: arancione = --secondary. Pensata mobile-first.
//
// Il muro è generato lato server come SVG (running bond, mattoni sfalsati): funziona anche senza JS.
// Lo script is:inline aggiunge solo la rivelazione riga-per-riga allo scroll.

const SHADES = ['#ff7300', '#f76e00', '#ff7d1c', '#fb7105', '#f56b00'];
const r2 = (n: number) => Math.round(n * 100) / 100;
const BAND = 3; // righe per banda animata

type Brick = { x: number; y: number; w: number; h: number; fill: string };
type Band  = { viewBox: string; bricks: Brick[] };

// Il muro è spezzato in "bande" HTML: la rivelazione va animata su elementi HTML,
// non su <g> SVG (IntersectionObserver e le transition CSS non funzionano sui <g>).
function buildWall(C: number, R: number, bw: number, bh: number, g: number): Band[] {
  const pitchX = bw + g, pitchY = bh + g;
  const wallW = C * bw + (C - 1) * g;
  const shade = (r: number, i: number) => SHADES[(r * 7 + i * 3) % SHADES.length];
  const bands: Band[] = [];
  for (let s = 0; s < R; s += BAND) {
    const e = Math.min(s + BAND, R);
    const yStart = s * pitchY;
    const bandH = (e - s) * pitchY - (e >= R ? g : 0);
    const bricks: Brick[] = [];
    for (let r = s; r < e; r++) {
      const odd = r % 2 === 1;
      const y = r * pitchY;
      if (!odd) {
        for (let i = 0; i < C; i++) bricks.push({ x: r2(i * pitchX), y, w: bw, h: bh, fill: shade(r, i) });
      } else {
        const off = -pitchX / 2;
        for (let j = 0; j <= C; j++) bricks.push({ x: r2(off + j * pitchX), y, w: bw, h: bh, fill: shade(r, j) });
      }
    }
    bands.push({ viewBox: `0 ${r2(yStart)} ${wallW} ${r2(bandH)}`, bricks });
  }
  return bands;
}

// Desktop/tablet: 20 × 50 = 1000.  Mobile: 10 × 100 = 1000 (muro più alto e drammatico).
const desktopBands = buildWall(20, 50, 20, 10, 2);
const mobileBands  = buildWall(10, 100, 20, 10, 2);
---

<figure class="brick-illustration" aria-labelledby="bi-lead-1">

  <section class="bi-scene bi-scene--one">
    <p class="bi-kicker">Reddito · Italia 1980 → 2024</p>
    <p class="bi-lead" id="bi-lead-1">
      Questi sono <strong>50&nbsp;€</strong>, quelli guadagnati dal <strong>10% più&nbsp;povero</strong> in 45&nbsp;anni.
    </p>
    <div class="bi-lone-wrap">
      <svg class="bi-lone-brick" viewBox="0 0 20 10" role="img" aria-label="Un mattoncino, pari a 50 euro">
        <rect x="0" y="0" width="20" height="10" rx="0.7" fill="#ff7300"></rect>
      </svg>
    </div>
    <p class="bi-unit">1 mattoncino = 50&nbsp;€</p>
    <div class="bi-scroll-cue" aria-hidden="true">Scorri<span class="bi-arrow">&darr;</span></div>
  </section>

  <section class="bi-scene bi-scene--many">
    <p class="bi-lead">
      Per avere un'idea, questi sono quelli guadagnati dal <strong>10% più&nbsp;ricco</strong>.
    </p>

    <div class="bi-wall-wrap">
      <div class="bi-wall-host" data-desktop role="img" aria-label="Un muro di 1000 mattoncini, pari a 50.000 euro">
        {desktopBands.map((band) => (
          <div class="bi-band">
            <svg class="bi-wall" viewBox={band.viewBox} preserveAspectRatio="xMidYMid meet" aria-hidden="true">
              {band.bricks.map((b) => (
                <rect x={b.x} y={b.y} width={b.w} height={b.h} rx="0.7" fill={b.fill}></rect>
              ))}
            </svg>
          </div>
        ))}
      </div>
      <div class="bi-wall-host" data-mobile role="img" aria-label="Un muro di 1000 mattoncini, pari a 50.000 euro">
        {mobileBands.map((band) => (
          <div class="bi-band">
            <svg class="bi-wall" viewBox={band.viewBox} preserveAspectRatio="xMidYMid meet" aria-hidden="true">
              {band.bricks.map((b) => (
                <rect x={b.x} y={b.y} width={b.w} height={b.h} rx="0.7" fill={b.fill}></rect>
              ))}
            </svg>
          </div>
        ))}
      </div>
    </div>

    <p class="bi-note">50&nbsp;mila euro. Cioè <strong>1000 mattoncini</strong>.</p>
  </section>

</figure>

<style>
  .brick-illustration {
    /* Palette ereditata dal tema, con fallback */
    --bi-pos:   var(--secondary, #ff7300);
    --bi-fg:    var(--fg, #1a1a1a);
    --bi-muted: var(--muted, #5b5b5b);
    --col: 600px;

    box-sizing: border-box;
    max-width: var(--col);
    margin: 0 auto;
    padding: 0 24px;
    color: var(--bi-fg);
    font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
  }
  .brick-illustration *, .brick-illustration *::before, .brick-illustration *::after { box-sizing: border-box; }

  /* ---- Scena 1: il mattoncino solitario ---- */
  .bi-scene--one {
    min-height: 100svh;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center; padding: 0px 0 48px;
  }
  .bi-kicker {
    font-size: 11px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--bi-pos); margin: 0 0 22px;
  }
  .bi-lead {
    font-size: clamp(20px, 5.2vw, 27px); line-height: 1.32; font-weight: 500;
    letter-spacing: -0.012em; margin: 0; max-width: 22ch; text-wrap: balance;
  }
  .bi-lead strong { font-weight: 700; }

  .bi-lone-wrap { margin: clamp(48px, 12vh, 96px) 0 18px; width: 100%; display: flex; justify-content: center; }
  .bi-lone-brick {
    width: calc(20 / 438 * 100%);   /* identico a un mattoncino del muro desktop */
    height: auto; display: block;
    animation: bi-brickIn .7s cubic-bezier(.2,.8,.2,1) both;
  }
  @keyframes bi-brickIn {
    from { opacity: 0; transform: translateY(10px) scale(.9); }
    to   { opacity: 1; transform: none; }
  }
  .bi-unit {
    font-size: 12px; color: var(--bi-muted); margin: 0;
    font-variant-numeric: tabular-nums; letter-spacing: 0.01em;
  }
  .bi-scroll-cue {
    margin-top: clamp(20px, 5vh, 80px);
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    font-size: 10.5px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--bi-muted);
  }
  .bi-arrow { font-size: 16px; line-height: 1; letter-spacing: 0; animation: bi-nudge 1.8s ease-in-out infinite; }
  @keyframes bi-nudge {
    0%, 100% { transform: translateY(0); opacity: .5; }
    50%      { transform: translateY(5px); opacity: 1; }
  }

  /* ---- Scena 2: il muro dei 1000 ---- */
  .bi-scene--many { padding: -10vh 0 18vh; }
  .bi-scene--many .bi-lead { text-align: left; margin: 0 0 34px; max-width: 26ch; }
  .bi-scene--many .bi-lead strong { color: var(--bi-pos); }

  .bi-wall-host { width: 100%; }
  .bi-wall-host[data-mobile] { display: none; }
  svg.bi-wall { width: 100%; height: auto; display: block; }

  .bi-band { display: block; will-change: opacity, transform; }
  .bi-js .bi-band {
    opacity: 0; transform: translateY(20px);
    transition: opacity .5s ease, transform .55s cubic-bezier(.2,.8,.2,1);
  }
  .bi-js .bi-band.in { opacity: 1; transform: none; }

  .bi-note {
    margin: 40px 0 0; font-size: clamp(16px, 4.4vw, 21px); line-height: 1.4;
    font-weight: 500; letter-spacing: -0.01em; text-align: right; color: var(--bi-fg);
  }
  .bi-note strong { font-weight: 700; color: var(--bi-pos); }

  /* ---- Mobile: muro 10 × 100, più alto ---- */
  @media (max-width: 560px) {
    .brick-illustration { padding: 0 18px; }
    .bi-lone-brick { width: calc(20 / 218 * 100%); }   /* identico a un mattoncino del muro mobile */
    .bi-wall-host[data-desktop] { display: none; }
    .bi-wall-host[data-mobile]  { display: block; }
    .bi-scene--many .bi-note { text-align: left; }
  }

  @media (prefers-reduced-motion: reduce) {
    .bi-js .bi-band { opacity: 1; transform: none; transition: none; }
    .bi-lone-brick, .bi-arrow { animation: none; }
  }
</style>

<script is:inline>
  (function () {
    var root = document.currentScript.closest('.brick-illustration') ||
               document.querySelector('.brick-illustration');
    if (!root) return;
    root.classList.add('bi-js');

    var bands = root.querySelectorAll('.bi-band');
    if (!('IntersectionObserver' in window)) {
      bands.forEach(function (b) { b.classList.add('in'); });
      return;
    }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
      });
    }, { rootMargin: '0px 0px -6% 0px', threshold: 0.04 });
    bands.forEach(function (b) { io.observe(b); });
  })();
</script>

---
---

<figure class="viz-figure">
  <div class="brick-chart" id="brick-chart">

    <header class="bc-head">
      <div class="bc-toggle" role="tablist" aria-label="Anno">
        <span class="bc-pill" aria-hidden="true"></span>
        <button type="button" class="is-active" data-year="1980" role="tab" aria-selected="true">1980</button>
        <button type="button" data-year="2024" role="tab" aria-selected="false">2024</button>
      </div>
    </header>

    <div class="bc-body">
      <div class="bc-grid-wrap">
        <svg id="bc-svg" role="img" aria-labelledby="bc-svg-title bc-svg-desc">
          <title id="bc-svg-title">Distribuzione del reddito nazionale italiano</title>
          <desc id="bc-svg-desc">Pittogramma di 100 mattoncini. Colorati in terracotta i mattoncini che spettano al 10% più ricco, in blu quelli del 10% più povero.</desc>
        </svg>
        <p class="bc-note">Ogni mattoncino = 1% del reddito nazionale</p>
      </div>
    </div>

    <footer class="bc-foot">
      <div class="bc-legend">
        <div class="bc-li"><span class="bc-sw" style="background: var(--bc-rich);"></span> 10% più ricco</div>
        <div class="bc-li"><span class="bc-sw" style="background: var(--bc-poor);"></span> 10% più povero</div>
      </div>
    </footer>

    <noscript>
      <table>
        <caption>Distribuzione del reddito nazionale italiano — dati chiave</caption>
        <thead>
          <tr>
            <th>Anno</th>
            <th>10% più ricco (% reddito)</th>
            <th>Reddito medio ricco</th>
            <th>10% più povero (% reddito)</th>
            <th>Reddito medio povero</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>1980</td><td>23,96%</td><td>€ 48.533</td><td>0,46%</td><td>€ 939</td></tr>
          <tr><td>2024</td><td>32,31%</td><td>€ 94.403</td><td>0,34%</td><td>€ 988</td></tr>
        </tbody>
      </table>
    </noscript>

  </div>
</figure>

<style is:global>
  .brick-chart {
    --bc-paper:    var(--bg);
    --bc-paper-2:  #f0f0f0;
    --bc-ink:      var(--fg);
    --bc-ink-soft: #3d3d3d;
    --bc-muted:    var(--muted);
    --bc-rule:     var(--border);
    --bc-rich:     var(--secondary);
    --bc-poor:     var(--tertiary);
    --bc-middle:   #e0e0e0;

    box-sizing: border-box;
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    color: var(--bc-ink);
    background: var(--bc-paper);
    padding: 36px 32px 32px;
    max-width: 560px;
    margin: 0 auto;
    border: 1px solid var(--bc-rule);
  }
  .brick-chart *, .brick-chart *::before, .brick-chart *::after { box-sizing: border-box; }

  /* —— Header strip —— */
  .brick-chart .bc-head {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 24px;
    border-bottom: 1px solid var(--bc-rule);
    padding-bottom: 18px;
    margin-bottom: 28px;
  }
  .brick-chart .bc-head-text { max-width: 38ch; }
  .brick-chart .bc-kicker {
    font-family: "IBM Plex Mono", monospace;
    font-size: 10.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--bc-rich);
    margin: 0 0 8px;
  }
  .brick-chart .bc-title {
    font-family: "Spectral", serif;
    font-weight: 400;
    font-size: 22px;
    line-height: 1.2;
    margin: 0;
    letter-spacing: -0.005em;
    text-wrap: balance;
  }

  /* —— Toggle —— */
  .brick-chart .bc-toggle {
    position: relative;
    display: inline-flex;
    background: var(--bc-paper-2);
    border: 1px solid var(--bc-rule);
    padding: 3px;
    flex-shrink: 0;
  }
  .brick-chart .bc-toggle .bc-pill {
    position: absolute;
    top: 3px;
    left: 3px;
    height: calc(100% - 6px);
    background: var(--bc-ink);
    transition: transform 0.45s cubic-bezier(.7, 0, .2, 1), width 0.45s cubic-bezier(.7, 0, .2, 1);
    z-index: 0;
  }
  .brick-chart .bc-toggle button {
    position: relative;
    z-index: 1;
    background: transparent;
    border: 0;
    cursor: pointer;
    padding: 10px 18px;
    font-family: "IBM Plex Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--bc-muted);
    transition: color 0.35s ease;
    -webkit-tap-highlight-color: transparent;
  }
  .brick-chart .bc-toggle button.is-active { color: var(--bc-paper); }
  .brick-chart .bc-toggle button:focus-visible { outline: 2px solid var(--bc-rich); outline-offset: 2px; }

  /* —— Layout: stats sidebar + grid —— */
  .brick-chart .bc-body {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    align-items: start;
  }

  /* —— SVG grid —— */
  .brick-chart .bc-grid-wrap { width: 100%; }
  .brick-chart .bc-grid-wrap svg { width: 100%; height: auto; display: block; }

  /* —— Stats —— */
  .brick-chart .bc-stats {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }
  .brick-chart .bc-stat {
    border-top: 1px solid var(--bc-rule);
    padding-top: 14px;
  }
  .brick-chart .bc-stat:first-child { border-top: 0; padding-top: 0; }
  .brick-chart .bc-stat .bc-stat-label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: "IBM Plex Mono", monospace;
    font-size: 10.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--bc-ink-soft);
    margin-bottom: 8px;
  }
  .brick-chart .bc-sw { width: 12px; height: 12px; display: inline-block; flex-shrink: 0; }
  .brick-chart .bc-stat .bc-stat-big {
    font-family: "Spectral", serif;
    font-size: 30px;
    line-height: 1.05;
    margin-bottom: 4px;
  }
  .brick-chart .bc-stat .bc-stat-big.is-rich { color: var(--bc-rich); }
  .brick-chart .bc-stat .bc-stat-big.is-poor { color: var(--bc-poor); }
  .brick-chart .bc-stat .bc-stat-sub {
    font-family: "IBM Plex Mono", monospace;
    font-size: 11px;
    color: var(--bc-muted);
    letter-spacing: 0.02em;
  }
  .brick-chart .bc-stat .bc-stat-sub b {
    color: var(--bc-ink);
    font-weight: 500;
  }

  /* —— Footer / legend —— */
  .brick-chart .bc-foot {
    margin-top: 28px;
    padding-top: 16px;
    border-top: 1px solid var(--bc-rule);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    font-family: "IBM Plex Mono", monospace;
    font-size: 10.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--bc-muted);
  }
  .brick-chart .bc-legend {
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
  }
  .brick-chart .bc-legend .bc-li {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* —— Grid caption —— */
  .brick-chart .bc-note {
    margin: 10px 0 0;
    font-family: "IBM Plex Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--bc-muted);
  }

  /* SVG label styles (used if axis labels are added in future) */
  .brick-chart svg .bc-axis-lbl {
    font-family: "IBM Plex Mono", monospace;
    font-size: 9px;
    fill: var(--bc-muted);
    letter-spacing: 0.04em;
  }

  /* —— Noscript fallback —— */
  .brick-chart noscript table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 16px;
    font-family: "IBM Plex Mono", monospace;
    font-size: 12px;
  }
  .brick-chart noscript th,
  .brick-chart noscript td {
    text-align: left;
    padding: 6px 10px;
    border: 1px solid var(--bc-rule);
  }
  .brick-chart noscript th {
    background: var(--bc-paper-2);
    font-weight: 500;
  }

  /* —— Responsive —— */
  @media (max-width: 640px) {
    .brick-chart {
      padding: 20px 12px;
      margin-left: -15px;
      margin-right: -15px;
    }
    .brick-chart .bc-head {
      flex-direction: column;
      align-items: center;
      gap: 18px;
    }
    .brick-chart .bc-body {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .brick-chart .bc-title { font-size: 20px; }
  }
</style>

<script type="module">
  import * as d3 from "https://cdn.jsdelivr.net/npm/d3@7/+esm";

  (() => {
    // -----------------------------------------------------------
    // Data
    // -----------------------------------------------------------
    const STATES = {
      '1980': { rich: 23.96, poor: 0.46, richEur: 48533, poorEur:  939, label: '1980' },
      '2024': { rich: 32.31, poor: 0.34, richEur: 94403, poorEur:  988, label: '2024' }
    };

    // -----------------------------------------------------------
    // Grid geometry
    // -----------------------------------------------------------
    const COLS = 10, ROWS = 10;
    const CELL = 42;
    const GAP  = 4;
    const PAD  = 6;
    const GRID = COLS * CELL + (COLS - 1) * GAP;
    const SIZE = GRID + PAD * 2;

    const cells = [];
    for (let r = 0; r < ROWS; r++) {
      for (let c = 0; c < COLS; c++) {
        cells.push({
          r, c,
          i_rich: r * COLS + c,
          i_poor: (ROWS - 1 - r) * COLS + c,
          x: PAD + c * (CELL + GAP),
          y: PAD + r * (CELL + GAP)
        });
      }
    }

    // How much of this cell (0..1) is filled at position i with percentage pct.
    const frac = (i, pct) => Math.max(0, Math.min(1, pct - i));

    // -----------------------------------------------------------
    // Build SVG
    // -----------------------------------------------------------
    const svg = d3.select('#bc-svg')
      .attr('viewBox', `0 0 ${SIZE} ${SIZE}`)
      .attr('preserveAspectRatio', 'xMidYMid meet');

    svg.append('g').attr('class', 'bc-bg-layer')
      .selectAll('rect')
      .data(cells)
      .join('rect')
        .attr('x', d => d.x)
        .attr('y', d => d.y)
        .attr('width',  CELL)
        .attr('height', CELL)
        .attr('fill',   'var(--bc-middle)')
        .attr('stroke', 'var(--bc-rule)')
        .attr('stroke-width', 0.5);

    const richSel = svg.append('g').attr('class', 'bc-rich-layer')
      .selectAll('rect')
      .data(cells)
      .join('rect')
        .attr('x', d => d.x)
        .attr('y', d => d.y)
        .attr('width', 0)
        .attr('height', CELL)
        .attr('fill', 'var(--bc-rich)');

    const poorSel = svg.append('g').attr('class', 'bc-poor-layer')
      .selectAll('rect')
      .data(cells)
      .join('rect')
        .attr('x', d => d.x)
        .attr('y', d => d.y)
        .attr('width', 0)
        .attr('height', CELL)
        .attr('fill', 'var(--bc-poor)');

    // -----------------------------------------------------------
    // Number formatting (Italian)
    // -----------------------------------------------------------
    const fmtPct = d3.format(',.2f');
    const fmtInt = d3.format(',.0f');
    const itaPct = v => fmtPct(v).replace('.', ',');
    const itaInt = v => fmtInt(v).replace(/,/g, '.');

    function tweenNumber(node, from, to, dur, fmt) {
      d3.select(node)
        .transition().duration(dur).ease(d3.easeCubicInOut)
        .tween('text', function() {
          const interp = d3.interpolateNumber(from, to);
          return function(t) { this.textContent = fmt(interp(t)); };
        });
    }

    // -----------------------------------------------------------
    // State + update
    // -----------------------------------------------------------
    let current = { rich: 0, poor: 0, richEur: 0, poorEur: 0 };
    const DURATION = 950;

    const nodeRichPct = document.getElementById('bc-rich-pct');
    const nodePoorPct = document.getElementById('bc-poor-pct');
    const nodeMidPct  = document.getElementById('bc-mid-pct');
    const nodeRichEur = document.getElementById('bc-rich-eur');
    const nodePoorEur = document.getElementById('bc-poor-eur');

    function update(year, animate = true) {
      const s = STATES[year];
      const dur = animate ? DURATION : 0;

      richSel.transition()
        .duration(dur)
        .ease(d3.easeCubicInOut)
        .attr('width', d => CELL * frac(d.i_rich, s.rich));

      poorSel.transition()
        .duration(dur)
        .ease(d3.easeCubicInOut)
        .attr('width', d => CELL * frac(d.i_poor, s.poor));

      tweenNumber(nodeRichPct, current.rich,    s.rich,    dur, v => `${itaPct(v)}%`);
      tweenNumber(nodePoorPct, current.poor,    s.poor,    dur, v => `${itaPct(v)}%`);
      tweenNumber(nodeMidPct,  100 - current.rich - current.poor,
                               100 - s.rich - s.poor,     dur, v => `${itaPct(v)}%`);
      tweenNumber(nodeRichEur, current.richEur, s.richEur, dur, v => `€ ${itaInt(v)}`);
      tweenNumber(nodePoorEur, current.poorEur, s.poorEur, dur, v => `€ ${itaInt(v)}`);

      current = { rich: s.rich, poor: s.poor, richEur: s.richEur, poorEur: s.poorEur };

      document.querySelectorAll('.brick-chart .bc-toggle button').forEach(b => {
        const on = b.dataset.year === year;
        b.classList.toggle('is-active', on);
        b.setAttribute('aria-selected', on ? 'true' : 'false');
      });
      movePill(year);
    }

    // -----------------------------------------------------------
    // Toggle pill positioning
    // -----------------------------------------------------------
    const pill    = document.querySelector('.brick-chart .bc-pill');
    const buttons = document.querySelectorAll('.brick-chart .bc-toggle button');

    function movePill(year) {
      const btn = document.querySelector(`.brick-chart .bc-toggle button[data-year="${year}"]`);
      if (!btn || !pill) return;
      const wrap    = btn.parentElement;
      const wrapRect = wrap.getBoundingClientRect();
      const btnRect  = btn.getBoundingClientRect();
      const x = btnRect.left - wrapRect.left - 3;
      pill.style.width     = `${btnRect.width}px`;
      pill.style.transform = `translateX(${x}px)`;
    }

    buttons.forEach(b => {
      b.addEventListener('click', () => update(b.dataset.year, true));
    });

    // -----------------------------------------------------------
    // Init
    // -----------------------------------------------------------
    requestAnimationFrame(() => {
      movePill('1980');
      update('1980', false);
    });

    window.addEventListener('resize', () => {
      const active = document.querySelector('.brick-chart .bc-toggle button.is-active');
      if (active) movePill(active.dataset.year);
    });
  })();
</script>

---
import Base from "../layouts/Base.astro";
import { site } from "../content/site";

const title = `Contatti — ${site.name}`;
---

<Base
  title={title}
  description={`Contatta ${site.name}`}
  canonicalPath="/contact"
  mainCentered
>
  <article class="prose">
    <h1>Contatti</h1>

    <p class="lead">
      Per domande, segnalazioni o collaborazioni, scrivici via email.
    </p>

    <p>
      Puoi raggiungerci a:
    </p>

    {site.author.email && (
      <p>
        <a href={`mailto:${site.author.email}`}>
          {site.author.email}
        </a>
      </p>
    )}

    <p>
      Leggiamo tutto, ma i tempi di risposta possono variare.
    </p>
  </article>
</Base>
